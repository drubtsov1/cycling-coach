# --- cycling-coach plugin (Intervals.icu MCP) ---

# Path to your `uv` binary (run `which uv` to check)
export UV_PATH="$HOME/.local/bin/uv"

# Path to your local clone of intervals-mcp-server
export INTERVALS_MCP_PATH="$HOME/cycling/intervals-mcp-server"

# Your Intervals.icu credentials (https://intervals.icu/settings → API)
export INTERVALS_API_KEY="your-api-key-here"
export INTERVALS_ATHLETE_ID="i123456"
